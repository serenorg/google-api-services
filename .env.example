# Google API Services Environment Variables

# Service ports (for local development)
GMAIL_PORT=8001
CALENDAR_PORT=8002
AUTH_PORT=8003

# Logging level
LOG_LEVEL=INFO

# --- Auth Service Configuration ---

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth callback URL (must match Google Cloud Console)
GOOGLE_REDIRECT_URI=http://localhost:8003/auth/google/callback

# Database for token storage (PostgreSQL)
DATABASE_URL=postgresql://seren:seren@localhost:5432/google_auth

# Encryption key for refresh tokens (32+ characters)
TOKEN_ENCRYPTION_KEY=your-32-character-encryption-key!

# Seren API URL (for validating API keys)
SEREN_API_URL=https://api.serendb.com
